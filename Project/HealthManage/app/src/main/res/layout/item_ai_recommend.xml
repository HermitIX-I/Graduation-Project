<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="100dp"
    android:background="@color/white"
    android:orientation="horizontal"
    android:gravity="center"
    android:padding="@dimen/margin_16dp"
    android:layout_margin="@dimen/margin_8dp"
    android:elevation="2dp"
    android:radius="@dimen/corner_12dp">

    <ImageView
        android:id="@+id/iv_motion_icon"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_motion_running" />

    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginLeft="@dimen/margin_16dp">

        <TextView
            android:id="@+id/tv_motion_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="30分钟慢跑"
            android:textColor="@color/black"
            android:textSize="@dimen/text_mid"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tv_motion_desc"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="适合心肺功能较弱人群，提升基础代谢"
            android:textColor="@color/gray"
            android:textSize="@dimen/text_small"
            android:layout_marginTop="@dimen/margin_4dp" />
    </LinearLayout>

    <TextView
        android:id="@+id/tv_go"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="开始运动"
        android:textColor="@color/color_health_green"
        android:textSize="@dimen/text_small"
        android:background="@drawable/shape_go_btn"
        android:padding="8dp" />

</LinearLayout>